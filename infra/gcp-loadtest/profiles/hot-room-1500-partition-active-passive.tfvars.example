# 1500-user active/passive hot-room profile with Hot Room Fan-out Partition v3 enabled.
# Compare against hot-room-1500-active-passive to verify that the same room's
# active fan-out work is split across Realtime partition owners.

profile               = "hot-room-1500-partition-active-passive"
api_count             = 1
realtime_count        = 4
api_machine_type      = "e2-standard-4"
realtime_machine_type = "e2-standard-8"
app_machine_type      = "e2-standard-8"
lb_machine_type       = "e2-standard-2"
mysql_machine_type    = "e2-standard-4"
redis_machine_type    = "e2-standard-4"
k6_machine_type       = "e2-standard-8"
k6_worker_count       = 2
shared_room_mode      = true
vus_list              = "1500"
chat_duration_seconds = 120
send_interval_ms      = 1000
connect_ramp_seconds  = 120
hot_rooms             = 1
scenario              = "k6/scenarios/10-active-passive-hot-room-ramped.js"
websocket_broadcast_lanes = 16

active_user_ratio            = 0.30
k6_sender_ratio              = 0.94
k6_observer_ratio            = 0.05
k6_validator_ratio           = 0.01
observer_send_interval_ms    = 0
active_heartbeat_interval_ms = 20000
passive_settle_ms            = 2000

room_shard_enabled                   = true
room_shard_shard_count               = 1
room_shard_legacy_subscribe_enabled  = false
room_partition_enabled               = true
room_partition_partition_count       = 4
room_partition_hot_tier_threshold    = "SMALL"
room_partition_max_partitions_per_room = 4

app_disk_size_gb        = 25
lb_disk_size_gb         = 10
mysql_disk_size_gb      = 30
redis_disk_size_gb      = 10
k6_disk_size_gb         = 10
monitoring_disk_size_gb = 15

enable_monitoring       = false
monitoring_machine_type = "e2-standard-2"
grafana_source_ranges   = []
