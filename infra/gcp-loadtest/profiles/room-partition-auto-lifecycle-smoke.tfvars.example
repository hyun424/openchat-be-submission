# End-to-end smoke for automatic room partition lifecycle scaling.
# Expected lifecycle: 1 -> 4 scale-up, reconnect redistribution, low-work drain, final scale-down.

profile               = "room-partition-auto-lifecycle-smoke"
api_count             = 1
realtime_count        = 2
api_machine_type      = "e2-standard-2"
realtime_machine_type = "e2-standard-4"
app_machine_type      = "e2-standard-4"
lb_machine_type       = "e2-standard-2"
mysql_machine_type    = "e2-standard-2"
redis_machine_type    = "e2-standard-2"
k6_machine_type       = "e2-standard-4"
k6_worker_count       = 1
k6_cleanup_enabled    = true
shared_room_mode      = false
vus_list              = "100"
chat_duration_seconds = 180
k6_ws_send_stop_after_seconds = 45
k6_chat_ack_p95_threshold_ms = 3000
send_interval_ms      = 200
connect_ramp_seconds  = 10
hot_rooms             = 1
scenario              = "k6/scenarios/11-mixed-room-workload-ramped.js"
websocket_broadcast_lanes = 8

active_user_ratio            = 1.0
k6_sender_ratio              = 1.0
k6_observer_ratio            = 0.0
k6_validator_ratio           = 0.0
observer_send_interval_ms    = 0
active_heartbeat_interval_ms = 20000
passive_settle_ms            = 2000

mixed_hot_room_count       = 1
mixed_hot_room_vus         = 100
mixed_hot_active_ratio     = 1.0
mixed_hot_send_interval_ms = 200
mixed_large_room_count     = 0
mixed_medium_room_count    = 0
mixed_small_room_count     = 0

room_shard_enabled                   = true
room_shard_shard_count               = 4
room_shard_legacy_subscribe_enabled  = false
room_partition_enabled               = true
room_partition_partition_count       = 4
room_partition_hot_tier_threshold    = "CRITICAL"
room_partition_max_partitions_per_room = 4
room_partition_admin_api_enabled     = false

room_scale_pod_work_budget_delivery_per_sec = 100
realtime_workload_publish_enabled     = true
realtime_workload_summary_enabled     = true
realtime_workload_publish_interval_ms = 2000
realtime_workload_snapshot_ttl_ms     = 10000
realtime_workload_top_room_limit      = 10

room_partition_lifecycle_enabled                              = true
room_partition_lifecycle_interval_ms                          = 2000
room_partition_lifecycle_scale_up_stable_window_ms            = 6000
room_partition_lifecycle_scale_up_min_observations            = 2
room_partition_lifecycle_scale_up_cooldown_ms                 = 20000
room_partition_lifecycle_scale_down_stable_window_ms          = 10000
room_partition_lifecycle_scale_down_min_observations          = 2
room_partition_lifecycle_scale_down_cooldown_ms               = 120000
room_partition_lifecycle_scale_down_min_partition_age_ms      = 10000
room_partition_lifecycle_drain_complete_empty_observations    = 2
room_partition_lifecycle_drain_reconnect_retry_after_ms       = 1000

app_disk_size_gb        = 20
lb_disk_size_gb         = 10
mysql_disk_size_gb      = 20
redis_disk_size_gb      = 10
k6_disk_size_gb         = 10
monitoring_disk_size_gb = 15

enable_monitoring       = false
monitoring_machine_type = "e2-standard-2"
grafana_source_ranges   = []
